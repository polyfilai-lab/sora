# Sora — environment variables
# Copy this file to .env for local dev. On Railway, set these in the Variables tab.

# Basic Auth — leave blank to disable (local dev). Set both on Railway.
SORA_USERNAME=
SORA_PASSWORD=

# Persistent data directory.
# Local: leave blank — defaults to ./data
# Railway: mount a Volume (e.g. /data) and set SORA_DATA_DIR=/data
SORA_DATA_DIR=

# Port (Railway sets this automatically; only needed for local override)
PORT=5070
